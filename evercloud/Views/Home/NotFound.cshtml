@{
    ViewData["Title"] = "Page Not Found";
    Layout = "~/Views/Shared/_Layout.cshtml"; // or your custom layout
}

<div class="container text-center py-5" style="min-height: 60vh;">
    <div class="card bg-dark border-0 shadow-lg p-4" style="border-radius: 2rem;">
        <div class="card-body">
            <h1 class="display-4 text-danger fw-bold mb-3">😕 404 - Not Found</h1>
            <p class="text-light fs-5 mb-4">
                The page you're looking for vanished into the cloud. <br />
                Maybe it never existed, or maybe it's just chilling somewhere else.
            </p>
            <a href="/" class="btn btn-outline-info btn-lg px-4 rounded-pill">
                ⬅ Back to Home
            </a>
        </div>
    </div>
</div>
