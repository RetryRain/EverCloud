@model List<evercloud.Domain.Models.AdminInboxUserViewModel>

<div class="p-2">

    <div class="container-sm py-4 mt-3 support-inbox-container">
        <h3 class="mb-4 text-warning">Support Inbox</h3>

        @if (Model.Count == 0)
        {
            <div>No support messages yet.</div>
        }
        else
        {
            <div class="list-group">
                @foreach (var user in Model)
                {
                    <a asp-action="AdminChat" asp-route-userId="@user.Id"
                       class="list-group-item d-flex justify-content-between align-items-center inbox-item">

                        <div class="mw-100">
                            <div class="d-flex justify-content-between">
                                <span class="d-inline-block fw-bold text-white inbox-username">@user.FullName</span>
                                <span class="d-inline-block">
                                    <img class="inbox" src="~/images/@(user.HasUnread ? "chat_unread.png" : "chat_read.png")" />
                                </span>
                            </div>

                            <div class="inbox-email">@user.Email</div>

                            @if (user.LastMessageTime.HasValue)
                            {
                                <div class="text-bg-secondary rounded-1 inbox-last-message mt-2 px-2 py-1 small text-wrap w-100">
                                    <span class="d-block d-md-inline">
                                        Last message: @user.LastMessageTime.Value.ToString("MMM dd, yyyy hh:mm tt")
                                    </span>
                                </div>
                            }

                        </div>

                    </a>
                }
            </div>
        }
    </div>

</div>
