@model evercloud.ViewModels.SupportChatViewModel

@{
    ViewData["Title"] = "Chat with User";
    var user = Model.SelectedUser;
    DateTime? lastDate = null;
}

<div class="vh-100 d-flex flex-column bg-dark" style="color: #cfcfcf;">

    <!-- Header -->
    <div class="container p-3 border-bottom border-secondary">
        <h3 class="mb-0">
            Chat with <span class="text-info fst-italic fs-5">
                <strong class="fst-normal fs-3">@user.FullName</strong> (@user.Email)
            </span>
        </h3>
    </div>

    <!-- Chat Message List (scrollable) -->
    <div id="chatMessages" class="container flex-grow-1 overflow-auto px-3 py-2 border-start border-end border-1">
        @foreach (var message in Model.Messages)
        {
            var isUser = message.Sender == "User";
            var messageDate = message.Timestamp.Date;

            // Insert date separator if the date changes
            if (lastDate == null || lastDate.Value.Date != messageDate)
            {
                <div class="text-center text-white my-3">
                    <strong>— @messageDate.ToString("MMMM dd, yyyy") —</strong>
                </div>
                lastDate = messageDate;
            }

            <div class="d-flex mb-3 @(isUser ? "justify-content-start" : "justify-content-end")">
                <div class="p-2 rounded-3"
                     style="max-width: 70%;
                                background-color: @(isUser ? "#00d4ff" : "#9b51e0");
                                color: @(isUser ? "black" : "white");">
                    <span>@message.MessageContent</span>
                    <div style="font-size: 0.7rem; opacity: 0.7;">
                        @message.Timestamp.ToShortTimeString()
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Sticky Chat Input -->
    <form asp-action="ReplyToUser" method="post" class="container border-top border-secondary bg-dark p-3 z-3 position-sticky bottom-0">
        <input type="hidden" name="userId" value="@user.Id" />
        <div class="input-group">
            <input type="text" name="message" class="form-control" placeholder="Type your reply..." required />
            <button class="btn btn-primary" type="submit">Send</button>
        </div>
    </form>

</div>

@section Scripts {
    <script>
        const chatBox = document.getElementById("chatMessages");
        if (chatBox) {
            chatBox.scrollTop = chatBox.scrollHeight;
        }
    </script>
}
